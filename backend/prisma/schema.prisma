generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  kakaoId            String   @unique
  name               String
  email              String?
  username           String?  @unique
  kakaoAccessToken   String?
  kakaoRefreshToken  String?
  googleRefreshToken String?
  timezone           String   @default("Asia/Seoul")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  eventTypes     EventType[]
  availabilities Availability[]
  hostBookings   Booking[]      @relation("HostBookings")
  guestBookings  Booking[]      @relation("GuestBookings")
}

model EventType {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  duration     Int
  bufferTime   Int      @default(0)
  maxGuests    Int      @default(1)
  slug         String
  locationType String   @default("online")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([userId, slug])
}

model Availability {
  id        String @id @default(cuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id @default(cuid())
  eventTypeId String
  hostId      String
  guestId     String
  startTime   DateTime
  endTime     DateTime
  status      String   @default("confirmed")
  meetLink    String?
  location    String?
  notes       String?
  guestName   String
  guestEmail  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventType EventType @relation(fields: [eventTypeId], references: [id])
  host      User      @relation("HostBookings", fields: [hostId], references: [id])
  guest     User      @relation("GuestBookings", fields: [guestId], references: [id])
}
